{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u9152\u4e95\u79d1\u534f\u6691\u57f9 2026","text":"<p>\u8fd9\u91cc\u662f 2026 \u9152\u4e95\u79d1\u534f\u6691\u57f9\u7684\u8bfe\u7a0b\u4e3b\u9875\u3002\u65e5\u540e\uff0c\u6211\u4eec\u5c06\u5728\u6b64\u96c6\u4e2d\u53d1\u5e03\u6240\u6709\u8bfe\u7a0b\u7684\u8bfe\u524d\u51c6\u5907\u6750\u6599\u3001\u8bfe\u7a0b\u8bb2\u4e49\u3001\u8bfe\u540e\u4f5c\u4e1a\u7b49\u5404\u79cd\u5185\u5bb9\u3002\u656c\u8bf7\u5173\u6ce8\uff01</p> <p> \u5ba3\u4f20\u63a8\u9001\uff1a[\u656c\u8bf7\u671f\u5f85]</p>"},{"location":"links/","title":"\u8d44\u6e90\u94fe\u63a5","text":"<p>\u672c\u9875\u9762\u7528\u4e8e\u5b58\u653e\u4e00\u4e9b\u6709\u7528\u7684\u8d44\u6e90\u94fe\u63a5\u3002</p>"},{"location":"links/#_2","title":"\u5b66\u4e60\u8d44\u6e90","text":"<p> \u8ba1\u7b97\u673a\u7cfb\u5b66\u751f\u79d1\u534f\u6280\u80fd\u5f15\u5bfc\u6587\u6863</p>"},{"location":"links/#_3","title":"\u5f80\u5e74\u6691\u57f9","text":"<ul> <li> <p>2025</p> </li> <li> <p>2024</p> </li> <li> <p>2023</p> </li> <li> <p>2022</p> </li> <li> <p>2021</p> </li> </ul>"},{"location":"ai/index_ai/","title":"AI Track","text":""},{"location":"ai/index_ai/#ai-overview","title":"AI Overview","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"ai/index_ai/#ml-system","title":"ML System","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"ai/index_ai/#llm","title":"LLM","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"ai/index_ai/#harness","title":"Harness","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"ai/index_ai/#diffusion","title":"Diffusion","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"ai/index_ai/#embodied-ai","title":"Embodied AI","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"ai/LLM/","title":"LLM","text":"<p>\u5927\u8bed\u8a00\u6a21\u578b\u6b63\u5728\u8fdb\u5165\u6211\u4eec\u7684\u73b0\u4ee3\u751f\u6d3b\uff1a\u4ece\u641c\u7d22\u95ee\u7b54\u3001\u5185\u5bb9\u521b\u4f5c\u4e0e\u4ee3\u7801\u5f00\u53d1\uff0c\u5230\u79d1\u7814\u8f85\u52a9\u3001\u65e5\u5e38\u529e\u516c\u548c\u5404\u7c7b\u667a\u80fd\u4f53\u7cfb\u7edf\uff0c\u5b83\u6b63\u5728\u6539\u53d8\u6211\u4eec\u83b7\u53d6\u4fe1\u606f\u3001\u89e3\u51b3\u95ee\u9898\u548c\u4e0e\u4e16\u754c\u4ea4\u4e92\u7684\u65b9\u5f0f\u3002\u8fd9\u4e9b\u80fd\u529b\u80cc\u540e\uff0c\u4e00\u4e2a\u5927\u8bed\u8a00\u6a21\u578b\u7a76\u7adf\u5982\u4f55\u7406\u89e3\u548c\u751f\u6210\u8bed\u8a00\uff1f\u5b83\u53c8\u662f\u600e\u6837\u4ece\u201c\u9884\u6d4b\u4e0b\u4e00\u4e2a\u8bcd\u201d\uff0c\u9010\u6e10\u6210\u4e3a\u80fd\u591f\u9075\u5faa\u6307\u4ee4\u3001\u8c03\u7528\u77e5\u8bc6\u5e76\u5b8c\u6210\u590d\u6742\u4efb\u52a1\u7684\u901a\u7528\u6a21\u578b\uff1f</p> <p>\u5728\u672c\u8282\u8bfe\u7a0b\u4e2d\uff0c\u6211\u4eec\u5c06\u6cbf\u7740\u4e00\u6761\u5b8c\u6574\u7684\u6280\u672f\u94fe\u8def\u8d70\u8fdb\u5927\u8bed\u8a00\u6a21\u578b\uff1a\u4ece\u6587\u672c\u5982\u4f55\u88ab\u5207\u5206\u4e3a Token\uff0c\u5230 Transformer \u5982\u4f55\u5904\u7406\u4e0a\u4e0b\u6587\uff1b\u4ece\u6d77\u91cf\u6570\u636e\u4e0a\u7684\u9884\u8bad\u7ec3\uff0c\u5230sft\u3001opd\u4e0erl\u7b49\u540e\u8bad\u7ec3\u65b9\u6cd5\uff0c\u518d\u5230\u6a21\u578b\u5982\u4f55\u5728\u63a8\u7406\u9636\u6bb5\u751f\u6210\u7b54\u6848\uff0c\u5e76\u8fdb\u4e00\u6b65\u8fde\u63a5\u5de5\u5177\u4e0e\u667a\u80fd\u4f53\u7cfb\u7edf\u3002\u540c\u65f6\uff0c\u6211\u4eec\u4e5f\u5c06\u6982\u89c8\u5927\u6a21\u578b\u80fd\u529b\u7684\u6765\u6e90\u4e0e\u8fb9\u754c\uff0c\u7406\u89e3\u5e7b\u89c9\u3001\u6548\u7387\u3001\u8bc4\u6d4b\u3001\u5b89\u5168\u548c\u53ef\u89e3\u91ca\u6027\u7b49\u5173\u952e\u95ee\u9898\u3002</p> <p>\u5b8c\u6210\u672c\u6b21\u8bfe\u7a0b\u540e\uff0c\u540c\u5b66\u4eec\u5c06\u5bf9\u5927\u8bed\u8a00\u6a21\u578b\u7684\u6570\u636e\u3001\u67b6\u6784\u3001\u8bad\u7ec3\u3001\u63a8\u7406\u3001\u5bf9\u9f50\u3001\u8bc4\u6d4b\u4e0e\u5e94\u7528\u5f62\u6210\u4e00\u5f20\u77e5\u8bc6\u5730\u56fe\uff0c\u7406\u89e3\u73b0\u4ee3 LLM \u4ece\u6570\u636e\u8d70\u5411\u667a\u80fd\u7cfb\u7edf\u7684\u8fc7\u7a0b\uff0c\u5e76\u521d\u6b65\u8ba4\u8bc6\u6a21\u578b\u7814\u7a76\u3001\u7cfb\u7edf\u4f18\u5316\u3001\u667a\u80fd\u4f53\u3001\u53ef\u89e3\u91ca\u6027\u4e0e AI \u5e94\u7528\u7b49\u4e0d\u540c\u65b9\u5411\u3002</p>"},{"location":"ai/ML/","title":"ML System","text":"<p>\u5f53\u6211\u4eec\u5728 PyTorch \u4e2d\u5199\u4e0b loss.backward() \u548c optimizer.step() \u65f6\uff0c\u8bad\u7ec3\u6846\u67b6\u3001GPU\u3001\u663e\u5b58\u4e0e\u901a\u4fe1\u7f51\u7edc\u5728\u80cc\u540e\u5206\u522b\u5b8c\u6210\u4e86\u4ec0\u4e48\u5de5\u4f5c\uff1f\u4e3a\u4ec0\u4e48\u6a21\u578b\u8d8a\u6765\u8d8a\u5927\u540e\uff0c\u5355\u7eaf\u589e\u52a0 GPU \u6570\u91cf\u5e76\u4e0d\u4e00\u5b9a\u80fd\u591f\u5e26\u6765\u7ebf\u6027\u7684\u8bad\u7ec3\u52a0\u901f\uff1f\u9762\u5bf9\u4e00\u4e2a\u8bad\u7ec3\u901f\u5ea6\u6162\u3001\u663e\u5b58\u4e0d\u8db3\u6216\u6269\u5c55\u6548\u7387\u4f4e\u7684\u95ee\u9898\uff0c\u6211\u4eec\u53c8\u8be5\u5982\u4f55\u627e\u5230\u74f6\u9888\uff0c\u5e76\u5c06\u5176\u8f6c\u5316\u4e3a\u4e00\u4e2a\u673a\u5668\u5b66\u4e60\u7cfb\u7edf\u7814\u7a76\u95ee\u9898\uff1f</p> <p>\u5728\u672c\u8282\u8bfe\u7a0b\u4e2d\uff0c\u6211\u4eec\u5c06\u4ee5 ML \u8bad\u7ec3\u7cfb\u7edf\u4e3a\u4e3b\u7ebf\uff0c\u4ecb\u7ecd\u673a\u5668\u5b66\u4e60\u7cfb\u7edf\u7684\u57fa\u672c\u7ed3\u6784\uff0c\u5305\u62ec\u6570\u636e\u52a0\u8f7d\u3001\u81ea\u52a8\u5fae\u5206\u3001\u8ba1\u7b97\u56fe\u3001\u7f16\u8bd1\u4e0e\u8fd0\u884c\u65f6\u3001GPU \u7b97\u5b50\u3001\u5206\u5e03\u5f0f\u901a\u4fe1\u3001\u5e76\u884c\u8bad\u7ec3\u3001\u4efb\u52a1\u8c03\u5ea6\u548c\u5bb9\u9519\u7b49\u6a21\u5757\u3002\u8bfe\u7a0b\u8fd8\u5c06\u68b3\u7406 MLSys \u4e2d\u5e38\u89c1\u7684\u91cd\u8981\u65b9\u6cd5\uff0c\u5982\u6df7\u5408\u7cbe\u5ea6\u8bad\u7ec3\u3001\u6570\u636e\u5e76\u884c\u3001\u5f20\u91cf\u5e76\u884c\u3001\u6d41\u6c34\u7ebf\u5e76\u884c\u3001ZeRO\u3001\u6fc0\u6d3b\u91cd\u8ba1\u7b97\u4e0e\u7b97\u5b50\u878d\u5408\uff0c\u5e2e\u52a9\u540c\u5b66\u4eec\u5efa\u7acb\u5bf9 ML \u8bad\u7ec3\u7cfb\u7edf\u5b8c\u6574\u6280\u672f\u6808\u7684\u521d\u6b65\u8ba4\u8bc6\u3002</p>"},{"location":"ai/diffusion/","title":"Diffusion","text":"<p>\u7b80\u4ecb\uff1a</p> <ol> <li>\u4ece\u5e95\u5c42\u539f\u7406\u4e0a\u5256\u6790 Diffusion \u6a21\u578b\uff0c\u5e26\u9886\u91cd\u6e29\u5b66\u4e60 DDPM\u3001DDIM\u3001Flow Matching \u7b49\u5f00\u521b\u6027\u7684 Diffusion \u539f\u7406\u5de5\u4f5c\uff1b</li> <li>\u8bb2\u89e3 Diffusion \u6a21\u578b\u7684\u5e38\u89c1\u67b6\u6784\uff0c\u4ece LDM \u5230 DiT\u3001MMDiT\uff0c\u8bb2\u89e3 Diffusion \u6a21\u578b\u67b6\u6784\u7684\u8fdb\u5316\u53f2\uff1b</li> <li>\u8ba8\u8bba Diffusion \u7684\u524d\u6cbf\u8bfe\u9898\uff0c\u5305\u62ec\u4f46\u4e0d\u9650\u4e8e Editting Models\u3001DiffusionOPD\u3001Memory\u3001High-Resolution\uff0c\u4ee5\u53ca\u5728\u5177\u8eab\u667a\u80fd\u548c\u751f\u7269\u5408\u6210\u9886\u57df\u7684\u5e94\u7528\u7b49\u3002</li> </ol>"},{"location":"ai/embodied/","title":"Embodied AI","text":"<p>\u5f53\u673a\u5668\u4eba\u7f6e\u8eab\u4e8e\u771f\u5b9e\u4e16\u754c\uff0c\u9762\u5bf9\u590d\u6742\u7684\u7269\u4f53\u3001\u73af\u5883\u4e0e\u4eba\u7c7b\u65f6\uff0c\u5b83\u5982\u4f55\u611f\u77e5\u5468\u56f4\u4fe1\u606f\uff0c\u5e76\u5728\u6b64\u57fa\u7840\u4e0a\u5b8c\u6210\u7406\u89e3\u3001\u51b3\u7b56\u4e0e\u884c\u52a8\uff1f\u6211\u4eec\u53c8\u8be5\u5982\u4f55\u8ba9\u667a\u80fd\u7cfb\u7edf\u771f\u6b63\u62e5\u6709\u201c\u8eab\u4f53\u201d\uff0c\u901a\u8fc7\u4e0e\u73af\u5883\u7684\u6301\u7eed\u4ea4\u4e92\u8fdb\u884c\u5b66\u4e60\u5e76\u5b8c\u6210\u4efb\u52a1\uff1f\u5728\u672c\u8282\u8bfe\u7a0b\u4e2d\uff0c\u6211\u4eec\u5c06\u4ecb\u7ecd\u5177\u8eab\u667a\u80fd\u7684\u57fa\u7840\u77e5\u8bc6\uff0c\u56f4\u7ed5\u611f\u77e5\u3001\u8ba4\u77e5\u3001\u89c4\u5212\u3001\u63a7\u5236\u4e0e\u5b66\u4e60\u7b49\u6838\u5fc3\u73af\u8282\u5c55\u5f00\u8bb2\u89e3\uff0c\u5e2e\u52a9\u540c\u5b66\u4eec\u521d\u6b65\u4e86\u89e3\u5177\u8eab\u667a\u80fd\u7cfb\u7edf\u7684\u57fa\u672c\u7ec4\u6210\u3001\u5178\u578b\u6280\u672f\u8def\u7ebf\u53ca\u5176\u53d1\u5c55\u73b0\u72b6\u3002</p> <p>\u5b8c\u6210\u672c\u6b21\u8bfe\u7a0b\u540e\uff0c\u6211\u4eec\u9884\u671f\u540c\u5b66\u80fd\u591f\u7406\u89e3\u5177\u8eab\u667a\u80fd\u7684\u57fa\u672c\u6982\u5ff5\u4e0e\u5de5\u4f5c\u6d41\u7a0b\uff0c\u8ba4\u8bc6\u5e38\u89c1\u5177\u8eab\u57fa\u5ea7\u6a21\u578b\u7684\u57fa\u672c\u539f\u7406\uff0c\u638c\u63e1\u5e38\u7528\u4eff\u771f\u73af\u5883\u7684\u57fa\u7840\u4f7f\u7528\u65b9\u6cd5\uff0c\u5e76\u80fd\u591f\u5728\u4eff\u771f\u5e73\u53f0\u4e2d\u8fd0\u884c\u548c\u590d\u73b0\u90e8\u5206\u7ecf\u5178\u7684\u5f00\u6e90\u6a21\u578b\u3002</p>"},{"location":"ai/harness/","title":"Harness","text":"<p>\u672c\u6b21\u5206\u4eab\u5c06\u5e26\u9886\u5927\u5bb6\u9605\u8bfb Claude Code \u6e90\u7801\uff0c\u6cbf\u7740\u771f\u5b9e Harness \u7684\u8fd0\u884c\u94fe\u8def\uff0c\u6df1\u5165\u5206\u6790\u4efb\u52a1\u5faa\u73af\u3001\u89c4\u5212\u673a\u5236\u3001\u4e0a\u4e0b\u6587\u7ba1\u7406\u3001\u5de5\u5177\u8c03\u7528\u3001\u8bb0\u5fc6\u673a\u5236\u4e0e\u5b50 Agent \u534f\u4f5c\u7b49\u6838\u5fc3\u8bbe\u8ba1\uff0c\u7406\u89e3\u8fd9\u4e9b\u80fd\u529b\u5982\u4f55\u5728\u5b9e\u9645\u7cfb\u7edf\u4e2d\u5b9e\u73b0\u3002</p>"},{"location":"ai/overview/","title":"AI Overview","text":"<p>\u672c\u8bb2\u9762\u5411\u521d\u5165\u8ba1\u7b97\u673a\u4e0e\u4eba\u5de5\u667a\u80fd\u9886\u57df\u3001\u5bf9\u73b0\u4ee3 AI \u6280\u672f\u4e86\u89e3\u4e0d\u591a\u7684\u521d\u5b66\u8005\u3002\u672c\u8bb2\u5c06\u4ece\u6570\u5b66\u5efa\u6a21\u3001\u6a21\u578b\u67b6\u6784\u3001Data \u548c Benchmark \u56db\u4e2a\u5c42\u6b21\u51fa\u53d1\uff0c\u4e3a\u5404\u4f4d\u521d\u5b66\u8005\u5c55\u73b0\u73b0\u4ee3 AI \u7cfb\u7edf\u4ece\u5b9a\u4e49\u5b66\u4e60\u5bf9\u8c61\u3001\u7ec4\u7ec7\u8ba1\u7b97\u8fc7\u7a0b\u3001\u5229\u7528\u6570\u636e\u8bad\u7ec3\u5230\u8bc4\u4f30\u6a21\u578b\u80fd\u529b\u7684\u57fa\u672c\u8fc7\u7a0b\u548c\u5173\u952e\u8981\u7d20\u3002\u540c\u65f6\uff0c\u672c\u8bb2\u5c06\u4ecb\u7ecd\u81ea\u56de\u5f52\u3001VAE\u3001GAN\u3001\u6269\u6563\u6a21\u578b\u3001Transformer\u3001MoE \u548c\u6a21\u578b\u91cf\u5316\u7b49\u5e38\u89c1\u6280\u672f\uff0c\u5e2e\u52a9\u5404\u4f4d\u521d\u5b66\u8005\u5efa\u7acb\u7406\u89e3 AI \u8bba\u6587\u3001\u6a21\u578b\u548c\u7cfb\u7edf\u7684\u6574\u4f53\u6846\u67b6\uff0c\u4e3a\u4eca\u540e\u7684\u8bfe\u7a0b\u5b66\u4e60\u3001\u79d1\u7814\u4e0e\u5de5\u7a0b\u5b9e\u8df5\u505a\u597d\u51c6\u5907\u3002</p>"},{"location":"basic/index_basic/","title":"\u57fa\u7840 Track","text":""},{"location":"basic/index_basic/#cs","title":"CS \u751f\u5b58\u6307\u5357","text":"<ul> <li>\u8bfe\u7a0b\u8bb2\u4e49</li> </ul>"},{"location":"basic/index_basic/#coding-agent","title":"Coding Agent","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"basic/coding-agent/","title":"Coding Agent","text":"<p>\u672c\u8bfe\u7a0b\u5e0c\u671b\u4ecb\u7ecd Coding Agent \u7684\u5de5\u4f5c\u65b9\u5f0f\u4e0e\u4f7f\u7528\u8fb9\u754c\u3002\u4f60\u5c06\u901a\u8fc7 Codex\u3001Claude Code \u7b49\u5de5\u5177\u5b8c\u6210\u4ece\u9700\u6c42\u6f84\u6e05\u3001\u9879\u76ee\u9605\u8bfb\u3001\u4efb\u52a1\u62c6\u5206\u5230\u4ee3\u7801\u4fee\u6539\u3001\u6d4b\u8bd5\u9a8c\u8bc1\u7684\u5b8c\u6574\u95ed\u73af\uff0c\u5e76\u52a8\u624b\u5236\u4f5c\u5c0f\u578b\u7f51\u9875\u5de5\u5177\u3002\u8bfe\u7a0b\u540c\u65f6\u8bb2\u89e3 agent loop\u3001\u6743\u9650\u63a7\u5236\u3001\u4e0a\u4e0b\u6587\u7ba1\u7406\u4e0e\u7ed3\u679c\u9a8c\u6536\uff0c\u5e2e\u52a9\u4f60\u628a\u201c\u8ba9 AI \u5199\u4ee3\u7801\u201d\u53d8\u6210\u53ef\u590d\u73b0\u3001\u53ef\u5ba1\u67e5\u3001\u53ef\u6301\u7eed\u8fed\u4ee3\u7684\u5de5\u4f5c\u6d41\u3002</p>"},{"location":"basic/survival-guide/","title":"CS \u751f\u5b58\u6307\u5357","text":"<p>\u672c\u8bb2\u9762\u5411\u521d\u5165\u8ba1\u7b97\u673a\u4e13\u4e1a\uff0c\u5bf9\u8ba1\u7b97\u673a\u6280\u672f\u4e86\u89e3\u4e0d\u591a\u7684\u5c0f\u767d\u3002\u672c\u8bb2\u4f1a\u901a\u8fc7\u4ecb\u7ecd\u4fe1\u606f\u68c0\u7d22\u7684\u57fa\u672c\u65b9\u5f0f\u548c\u5e38\u89c1\u6e20\u9053\uff0c\u4e3a\u5404\u4f4d\u8ba1\u7b97\u673a\u521d\u5b66\u8005\u5c55\u73b0\u5229\u7528\u8ba1\u7b97\u673a\u548c\u7f51\u7edc\u89e3\u51b3\u95ee\u9898\u7684\u57fa\u672c\u8fc7\u7a0b\u548c\u8981\u7d20\u3002\u540c\u65f6\uff0c\u672c\u8bb2\u901a\u8fc7\u4ecb\u7ecd\u6700\u5e38\u89c1\u7684\u82e5\u5e72\u8ba1\u7b97\u673a\u6280\u672f\uff08\u5982 Linux \u548c Git\uff09\uff0c\u4e3a\u5404\u4f4d\u8ba1\u7b97\u673a\u521d\u5b66\u8005\u5728\u672a\u6765\u7684\u79d1\u7814\u548c\u5de5\u4f5c\u5feb\u901f\u4e0a\u624b\u5de5\u7a0b\u4e0e\u5b9e\u9a8c\u73af\u5883\u505a\u597d\u51c6\u5907\u3002</p> <p>\u6ce8\uff1a\u672c\u8bb2\u6574\u4f53\u5185\u5bb9\u504f\u57fa\u7840\uff0c\u4e0d\u9002\u5408\u6709\u4e00\u5b9a\u8ba1\u7b97\u673a\u77e5\u8bc6\u7684\u540c\u5b66\u53c2\u52a0\u3002</p>"},{"location":"basic/survival-guide/#_1","title":"\u8bfe\u7a0b\u8bb2\u4e49","text":"<p>CS \u9886\u57df\u5e38\u89c1\u5b66\u4e60\u8d44\u6e90\u5165\u53e3</p>"},{"location":"basic/survival-guide/cs-resources/","title":"CS \u9886\u57df\u5e38\u89c1\u5b66\u4e60\u8d44\u6e90\u5165\u53e3","text":""},{"location":"basic/survival-guide/cs-resources/#_1","title":"\u8bfe\u7a0b\u7c7b","text":"<ul> <li>CS \u81ea\u5b66\u6307\u5357</li> <li>MIT Missing Semester</li> <li>OSSU Computer Science</li> <li>Teach Yourself CS</li> <li>MIT OpenCourseWare</li> <li>Harvard CS50</li> <li>UC Berkeley CS61A</li> <li>Stanford CS106B</li> <li>SAST Summer 2025</li> <li>SAST Summer 2024</li> </ul>"},{"location":"basic/survival-guide/cs-resources/#_2","title":"\u6280\u672f\u7c7b\uff1a\u8bed\u8a00 / \u6846\u67b6 / \u5de5\u5177","text":"<ul> <li>MDN Web Docs</li> <li>Python Docs</li> <li>The Rust Book</li> <li>Go Documentation</li> <li>cppreference</li> <li>Java Documentation</li> <li>React Docs</li> <li>Vue Docs</li> <li>Django Docs</li> <li>Docker Docs</li> <li>Kubernetes Docs</li> <li>Git Book</li> <li>GitHub Docs</li> </ul>"},{"location":"basic/survival-guide/cs-resources/#_3","title":"\u5b66\u672f\u7c7b\uff1a\u8bba\u6587 / \u7814\u7a76\u65b9\u5411","text":"<ul> <li>Google Scholar</li> <li>arXiv</li> <li>Semantic Scholar</li> <li>Papers with Code</li> <li>DBLP</li> <li>ACM Digital Library</li> <li>IEEE Xplore</li> <li>Connected Papers</li> <li>ResearchRabbit</li> </ul>"},{"location":"basic/survival-guide/cs-resources/#_4","title":"\u793e\u533a\u4e0e\u95ee\u9898\u68c0\u7d22","text":"<ul> <li>Stack Overflow</li> <li>GitHub Issues</li> <li>GitHub Discussions</li> <li>Hacker News</li> <li>Reddit r/learnprogramming</li> <li>V2EX</li> <li>SegmentFault</li> </ul>"},{"location":"basic/survival-guide/cs-resources/#_5","title":"\u5de5\u5177/\u767e\u79d1/\u9898\u5e93/\u6a21\u578b","text":"<ul> <li>tldr pages</li> <li>explainshell</li> <li>man7 Linux man-pages</li> <li>ArchWiki</li> <li>OI Wiki</li> <li>LeetCode</li> <li>Codeforces</li> <li>\u6d1b\u8c37</li> <li>Kaggle</li> <li>Hugging Face</li> </ul>"},{"location":"basic/survival-guide/cs-resources/#_6","title":"\u5b89\u5168 / \u7f51\u7edc / \u7cfb\u7edf\u8865\u5145","text":"<ul> <li>OWASP</li> <li>SEED Labs</li> <li>Computer Networking: A Top-Down Approach</li> <li>Linux Journey</li> <li>The Linux Documentation Project</li> </ul>"},{"location":"cyber/index_cyber/","title":"Cyber Track","text":""},{"location":"cyber/index_cyber/#llm","title":"LLM \u4e0e\u7f51\u7edc\u5b89\u5168","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"cyber/cyber/","title":"LLM \u4e0e\u7f51\u7edc\u5b89\u5168","text":"<p>\u7f51\u7edc\u5b89\u5168\u662f\u8ba1\u7b97\u673a\u79d1\u5b66\u7684\u4e00\u4e2a\u5206\u652f\uff0c\u7f51\u7edc\u5b89\u5168\u4efb\u52a1\u901a\u5e38\u9700\u8981\u7075\u6d3b\u8fd0\u7528\u8ba1\u7b97\u673a\u7cfb\u7edf\u3001\u7f51\u7edc\u4ee5\u53ca\u5bc6\u7801\u5b66\u7b49\u8de8\u9886\u57df\u7684\u77e5\u8bc6\u3002\u5728\u672c\u8282\u8bfe\u7a0b\u4e2d\uff0c\u8bb2\u5e08\u5c06\u521d\u6b65\u4ecb\u7ecd\u7f51\u7edc\u5b89\u5168\u8fd9\u4e00\u9886\u57df\uff0c\u4ee5\u53ca\u4e8c\u8fdb\u5236\u3001\u5bc6\u7801\u5b66\u3001web \u5b89\u5168\u3001\u9006\u5411\u5de5\u7a0b\u7b49\u5b50\u9886\u57df\u7684\u77e5\u8bc6\u5730\u56fe\u3002</p> <p>\u968f\u7740 LLM \u7684\u4ee3\u7801\u3001\u63a8\u7406\u3001\u591a\u8f6e\u4ea4\u4e92\u80fd\u529b\u65e5\u76ca\u589e\u5f3a\uff0cLLM Agent \u4e5f\u5f00\u59cb\u6267\u884c\u66f4\u52a0\u957f\u7a0b\u3001\u590d\u6742\u3001\u4f9d\u8d56\u4e13\u4e1a\u77e5\u8bc6\u7684\u7f51\u7edc\u5b89\u5168\u4efb\u52a1\u3002\u672c\u8282\u8bfe\u7a0b\u4e2d\u8fd8\u5c06\u4ecb\u7ecd\u524d\u6cbf LLM \u5728\u7f51\u7edc\u5b89\u5168\u9886\u57df\u7684\u8fdb\u5c55\uff0c\u5e76\u4ecb\u7ecd\u4f7f\u7528 LLM Agent \u6267\u884c\u7f51\u7edc\u5b89\u5168\u4efb\u52a1\u7684\u6700\u4f73\u5b9e\u8df5\u3002</p>"},{"location":"frontend-and-backend/index_frontend-and-backend/","title":"\u524d\u540e\u7aef Track","text":""},{"location":"frontend-and-backend/index_frontend-and-backend/#_1","title":"\u524d\u7aef","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"frontend-and-backend/index_frontend-and-backend/#_2","title":"\u540e\u7aef","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"frontend-and-backend/backend/","title":"\u540e\u7aef","text":"<p>\u540e\u7aef\uff0c\u4e0d\u53ea\u662f\u5199\u63a5\u53e3\u3002\u53ef\u9760\u7684\u670d\u52a1\u4e5f\u4e0d\u80fd\u9760\u7eaf vibe coding\u3002AI \u65f6\u4ee3\u4e0d\u518d\u9700\u8981\u9010\u884c\u624b\u6572\u4ee3\u7801\uff0c\u4f46\u8f6f\u4ef6\u5de5\u7a0b\u7684\u601d\u60f3\u5185\u6838\u6ca1\u6709\u53d8\uff0c\u8fd9\u4e9b insight \u4ecd\u7136\u662f\u9a7e\u9a6d AI \u5de5\u5177\u7684\u524d\u63d0\uff0c\u800c\u4e0d\u662f\u53ef\u4ee5\u88ab\u8df3\u8fc7\u7684\u7ae0\u8282\u3002</p> <p>\u672c\u6b21\u5206\u4eab\u5c06\u4ece\u96f6\u68b3\u7406\u540e\u7aef\u5f00\u53d1\u7684\u6838\u5fc3\u8109\u7edc\uff1a\u4ece API \u8def\u7531\u4e0e RESTful \u8bbe\u8ba1\uff0c\u5230\u4e2d\u95f4\u4ef6\u5982\u4f55\u4e32\u8054\u8bf7\u6c42\u94fe\u8def\uff1b\u4ece\u300c\u7ed9\u5b9a\u4e1a\u52a1\u9700\u6c42\u600e\u4e48\u8bbe\u8ba1\u6570\u636e\u6a21\u578b\u300d\uff0c\u5230\u7f13\u5b58\u5982\u4f55\u5e2e\u670d\u52a1\u625b\u4f4f\u9ad8\u5e76\u53d1\u3002\u540c\u65f6\u4e5f\u4f1a\u6d89\u53ca\u5f00\u53d1\u89c4\u8303\u3001\u6d4b\u8bd5\u4e0e CI/CD \u6d41\u6c34\u7ebf\uff0c\u4ee5\u53ca Docker \u5bb9\u5668\u5316\u90e8\u7f72\u7684\u5b9e\u9645\u64cd\u4f5c\u6f14\u793a\u3002\u4e0d\u8bb2\u7a7a\u4e2d\u697c\u9601\uff0c\u6bcf\u4e00\u6b65\u90fd\u843d\u5728\u4f60\u672a\u6765\u771f\u6b63\u4f1a\u5199\uff08\u6216\u8005\u6307\u6325 Agent \u5199\uff09\u7684\u4ee3\u7801\u4e0a\u3002\u672c\u6b21\u5206\u4eab\u5b8c\u5168\u652f\u6301\u96f6\u57fa\u7840\uff0c\u5e26\u4e0a\u4f60\u5bf9\u300c\u4e00\u4e2a\u7f51\u7ad9\u80cc\u540e\u5728\u53d1\u751f\u4ec0\u4e48\u300d\u7684\u597d\u5947\u5fc3\u5c31\u591f\u4e86\u3002</p>"},{"location":"frontend-and-backend/frontend/","title":"\u524d\u7aef","text":"<p>\u524d\u7f6e\u77e5\u8bc6\uff1a\u65e0\u9700\u524d\u7aef\u57fa\u7840\uff0c\u5177\u5907\u7b80\u5355\u7684\u7f16\u7a0b\u77e5\u8bc6\u5373\u53ef</p> <p>\u8bfe\u7a0b\u4ecb\u7ecd\uff1a\u524d\u7aef\u5f00\u53d1\u4e0d\u4ec5\u662f\u7f16\u5199\u7f51\u9875\u754c\u9762\uff0c\u8fd8\u6d89\u53ca\u6d4f\u89c8\u5668\u8fd0\u884c\u673a\u5236\u3001\u5de5\u7a0b\u5316\u6784\u5efa\u4ee5\u53ca\u9879\u76ee\u90e8\u7f72\u7b49\u4e00\u6574\u5957\u6d41\u7a0b\u3002\u672c\u6b21\u5206\u4eab\u5c06\u4ece\u524d\u7aef\u7684\u6574\u4f53\u77e5\u8bc6\u5730\u56fe\u51fa\u53d1\uff0c\u4ecb\u7ecd\u73b0\u4ee3\u524d\u7aef\u7684\u5b66\u4e60\u8def\u7ebf\u4e0e\u6838\u5fc3\u6280\u672f\uff0c\u5e2e\u52a9\u540c\u5b66\u4eec\u7406\u89e3\u7f51\u9875\u4ece\u4ee3\u7801\u5230\u6700\u7ec8\u5448\u73b0\u5728\u6d4f\u89c8\u5668\u4e2d\u7684\u5b8c\u6574\u8fc7\u7a0b\u3002\u8bfe\u7a0b\u5c06\u4e3b\u8981\u6db5\u76d6\u73b0\u4ee3\u524d\u7aef\u7684\u8fd0\u884c\u539f\u7406\u3001\u9879\u76ee\u6784\u5efa\u6d41\u7a0b\uff0c\u4ee5\u53ca\u5982\u4f55\u501f\u52a9 AI \u5de5\u5177\u5feb\u901f \u201cvibe\u201d \u51fa\u4e00\u4e2a\u53ef\u4ee5\u8fd0\u884c\u7684\u524d\u7aef\u9879\u76ee\u3002\u6b64\u5916\uff0c\u8fd8\u4f1a\u5206\u4eab\u4e00\u4e9b\u5b9e\u9645\u5f00\u53d1\u4e2d\u5341\u5206\u6709\u7528\u7684\u5de5\u5177\u3001\u6280\u5de7\u4e0e\u7ecf\u9a8c\uff0c\u5e76\u63d0\u4f9b\u76f8\u5173\u535a\u5ba2\u548c\u5b66\u4e60\u8d44\u6599\uff0c\u65b9\u4fbf\u540c\u5b66\u4eec\u5728\u8bfe\u540e\u8fdb\u4e00\u6b65\u5de9\u56fa\u548c\u62d3\u5c55\u3002</p>"},{"location":"research/index_research/","title":"\u79d1\u7814 Track","text":""},{"location":"research/index_research/#_1","title":"\u79d1\u7814\u5206\u4eab\uff08\u4e00\uff09","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"research/index_research/#_2","title":"\u79d1\u7814\u5206\u4eab\uff08\u4e8c\uff09","text":"<ul> <li>\u8bfe\u7a0b\u7b80\u4ecb</li> </ul>"},{"location":"research/first/","title":"\u79d1\u7814\u5206\u4eab\uff08\u4e00\uff09","text":"<p>\u79d1\u7814\u662f\u8bb8\u591a\u540c\u5b66\u8fdb\u5165\u6e05\u534e\u540e\u65e2\u5411\u5f80\u53c8\u611f\u5230\u964c\u751f\u7684\u4e00\u4ef6\u4e8b\uff1a\u5b83\u503c\u5f97\u6295\u5165\u5417\uff1f\u4ece\u54ea\u91cc\u5f00\u59cb\uff1f\u548c\u8bfe\u5185\u5b66\u4e60\u6709\u4ec0\u4e48\u4e0d\u540c\uff1f\u672c\u6b21\u8bb2\u5ea7\u5c06\u4ece\u4e3b\u8bb2\u4eba\u7684\u7ecf\u5386\u51fa\u53d1\uff0c\u5b8c\u6574\u68b3\u7406\u4ece\u840c\u751f\u5174\u8da3\u5230\u6df1\u5165\u79d1\u7814\u7684\u5168\u8fc7\u7a0b\uff0c\u4e3a\u5927\u4e00\u5927\u4e8c\u7684\u540c\u5b66\u5448\u73b0\u4e00\u4efd\u53ef\u64cd\u4f5c\u7684\u79d1\u7814\u5165\u95e8\u6307\u5357\u3002</p> <p>\u8bb2\u5ea7\u5c06\u9996\u5148\u56de\u7b54\"\u8981\u4e0d\u8981\u505a\u79d1\u7814\"\u8fd9\u4e2a\u95ee\u9898\u3002\u6211\u4eec\u4f1a\u804a\u804a\u9009\u62e9\u79d1\u7814\u7684\u7406\u7531\uff0c\u4e5f\u4f1a\u8fd8\u539f\u4e00\u6bb5\u771f\u5b9e\u7684\u672c\u79d1\u4f4e\u5e74\u7ea7\u79d1\u7814\u7ecf\u5386\u3002\u5e0c\u671b\u901a\u8fc7\u8fd9\u4e9b\u771f\u5b9e\u7ec6\u8282\uff0c\u5e2e\u52a9\u5927\u5bb6\u5efa\u7acb\u5bf9\u79d1\u7814\u7684\u5408\u7406\u9884\u671f\u3002</p> <p>\u5728\u6b64\u57fa\u7840\u4e0a\uff0c\u8bb2\u5ea7\u5c06\u7cfb\u7edf\u4ecb\u7ecd\u79d1\u7814\u8d77\u6b65\u7684\u4e09\u4e2a\u5173\u952e\u73af\u8282\uff1a\u8fdb\u7ec4\u524d\u9700\u8981\u505a\u54ea\u4e9b\u51c6\u5907\u3001\u5982\u4f55\u9009\u62e9\u5408\u9002\u7684\u8bfe\u9898\u7ec4\u4e0e\u5bfc\u5e08\u3001\u5982\u4f55\u9010\u6b65\u786e\u5b9a\u81ea\u5df1\u7684\u7814\u7a76\u65b9\u5411\u3002\u8fdb\u7ec4\u4e4b\u540e\uff0c\u9ad8\u6548\u8bfb\u8bba\u6587\u7684\u65b9\u6cd5\u3001\u4e0e\u5b66\u957f\u548c\u8001\u5e08\u7684\u6c9f\u901a\u6280\u5de7\u3001\u8bfe\u5185\u5b66\u4e60\u4e0e\u79d1\u7814\u65f6\u95f4\u7684\u5e73\u8861\u7b56\u7565\uff0c\u90fd\u662f\u65b0\u4eba\u6700\u5e38\u9047\u5230\u7684\u96be\u9898\uff0c\u4e3b\u8bb2\u4eba\u5c06\u7ed3\u5408\u81ea\u5df1\u521d\u5165\u9886\u57df\u65f6\u7684\u63a2\u7d22\u7ecf\u5386\uff0c\u7ed9\u51fa\u5177\u4f53\u53ef\u884c\u7684\u5efa\u8bae\u3002</p> <p>\u5bf9\u4e8e\u540c\u5b66\u4eec\u666e\u904d\u5173\u5fc3\u7684\u53d1\u5c55\u8def\u5f84\u95ee\u9898\uff0c\u8bb2\u5ea7\u8fd8\u5c06\u4e13\u95e8\u8ba8\u8bba\u4fdd\u7814\u4e0e\u51fa\u56fd\u4e24\u6761\u9053\u8def\uff1a\u4e24\u8005\u5404\u81ea\u7684\u8bc4\u4ef7\u6807\u51c6\u662f\u4ec0\u4e48\u3001\u9700\u8981\u5728\u4ec0\u4e48\u65f6\u95f4\u8282\u70b9\u505a\u51fa\u9009\u62e9\u3001\u5927\u4e00\u5927\u4e8c\u9636\u6bb5\u53ef\u4ee5\u505a\u54ea\u4e9b\u8ba9\u4e24\u4e2a\u9009\u9879\u90fd\u4fdd\u6301\u6253\u5f00\u7684\u51c6\u5907\u3002\u4e3b\u8bb2\u4eba\u5c06\u7ed3\u5408\u81ea\u5df1\u5728\u56fd\u5916\u505a\u79d1\u7814\u548c\u6d77\u5916\u6691\u671f\u79d1\u7814\u7684\u7ecf\u5386\uff0c\u5206\u4eab\u6691\u7814\u7533\u8bf7\u3001\u63a8\u8350\u4fe1\u79ef\u7d2f\u4e0e\u7533\u8bf7\u5b63\u89c4\u5212\u7684\u5b9e\u7528\u7ecf\u9a8c\u3002\u6700\u540e\uff0c\u8bb2\u5ea7\u5c06\u4ee5\u5bf9\u79d1\u7814\u7684\u6574\u4f53\u601d\u8003\u4e0e\u4e2a\u4eba\u89c4\u5212\u6536\u5c3e\uff0c\u6b22\u8fce\u5e26\u7740\u4f60\u7684\u56f0\u60d1\u524d\u6765\u4ea4\u6d41\u3002</p>"},{"location":"research/second/","title":"\u79d1\u7814\u5206\u4eab\uff08\u4e8c\uff09","text":""},{"location":"research/second/#_2","title":"\u79d1\u7814\u7b2c\u4e00\u6b65\uff1a\u4ece\u7b2c\u4e00\u6b21\u8bfb\u8bba\u6587\u5230\u7b2c\u4e00\u6b21\u53d1\u8bba\u6587","text":"<p>\u672c\u6b21\u5206\u4eab\u9762\u5411\u521a\u5f00\u59cb\u63a5\u89e6\u79d1\u7814\u6216\u5e0c\u671b\u4e86\u89e3\u79d1\u7814\u7684\u5927\u4e00\u5927\u4e8c\u540c\u5b66\uff0c\u7b80\u5355\u4ecb\u7ecd\u5982\u4f55\u8ba4\u8bc6\u79d1\u7814\u3001\u9009\u62e9\u65b9\u5411\u5e76\u5feb\u901f\u5b8c\u6210\u79d1\u7814\u5165\u95e8\u3002\u5206\u4eab\u5c06\u7ed3\u5408\u4e3b\u8bb2\u4eba\u672c\u79d1\u9636\u6bb5\u5728AI\u9886\u57df\u7c97\u6d45\u7684\u79d1\u7814\u63a2\u7d22\uff0c\u91cd\u70b9\u8ba8\u8bba\u4ec0\u4e48\u65f6\u5019\u5f00\u59cb\u79d1\u7814\uff0c\u5982\u4f55\u6b63\u786e\u5b9a\u4f4d\u79d1\u7814\u4e0e\u8bfe\u4e1a\uff0c\u5982\u4f55\u5feb\u901f\u5165\u95e8\u4e0a\u624b\u7b49\u672c\u79d1\u751f\u79d1\u7814\u5e38\u89c1\u95ee\u9898\uff0c\u5e76\u7b80\u8981\u5206\u4eab\u8bba\u6587\u9605\u8bfb\u3001\u5b9e\u9a8c\u5b9e\u8df5\u3001\u79d1\u7814\u5de5\u5177\u4f7f\u7528\u3001AI\u8f85\u52a9\u79d1\u7814\u4ee5\u53ca\u79d1\u7814\u8fc7\u7a0b\u4e2d\u7684\u601d\u8003\u65b9\u6cd5\u3002</p>"}]}